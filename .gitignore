# =============================================================================
# smashegg .gitignore
# =============================================================================

# --- Local-only notes (reference other local projects; never pushed) ---
docs/local/

# --- Security (NEVER COMMIT) ---
.env
.env.local
.env.*.local
.dev.vars
.dev.vars.*
!.dev.vars.example
*.pem
*.key

# --- Cloudflare / Wrangler local state (local DO SQLite + caches; may hold
#     seeded/test room data) ---
.wrangler/
wrangler.local.toml
wrangler.local.jsonc

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tsbuildinfo

# --- Build output (regenerate: npm run build) ---
dist/

# --- Test & coverage artifacts (regenerate by running tests) ---
coverage/
.vite/
test-results/
playwright-report/
blob-report/
playwright/.cache/
# e2e rare-path PROOF-LEVEL summary (tests/e2e/product-paths.e2e.test.ts) —
# machine-readable record of the proof level each run achieved; regenerated
# every run, never a source-of-truth artifact.
tests/e2e/.proof-levels.json

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.TemporaryItems

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Claude Code (local agent state, not source) ---
# `.claude/*` (not `.claude/`) so the ONE shared file below can be negated:
# git cannot re-include a file whose parent DIRECTORY is excluded.
.claude/*
# Committed on purpose: repo-level model dispatch default (PLAN §9 policy —
# sessions in this repo default to Opus; Fable is escalation-only).
!.claude/settings.json

# --- Logs ---
*.log

# =============================================================================
# EXPLICITLY TRACKED (do NOT ignore these)
# =============================================================================
# src/                 — engine / server / client / shared source
# tests/               — unit (and later e2e) tests
# docs/                — rules spec, research provenance, methodology
# .github/workflows/   — CI/CD
# wrangler.jsonc       — deploy config (no secrets; secrets live in
#                        GitHub Actions secrets and `wrangler secret`)
# .dev.vars.example    — documented local-secrets template (negated above)
