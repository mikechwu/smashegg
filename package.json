{
  "name": "smashegg",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "vite build",
    "build:release": "BUILD_VERSION=$(git rev-parse HEAD) vite build",
    "dev:client": "vite",
    "cf:dev": "wrangler dev",
    "typecheck": "tsc --noEmit -p tsconfig.engine.json && tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.client.json && tsc --noEmit -p tsconfig.scripts.json",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "deploy": "SHA=$(git rev-parse HEAD) && BUILD_VERSION=$SHA vite build && wrangler deploy --var BUILD_VERSION:$SHA",
    "lint:hooks": "eslint src/client"
  },
  "dependencies": {
    "partysocket": "^1.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.7",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.0.11",
    "vitest": "^3.0.5",
    "wrangler": "^4.0.0"
  }
}
